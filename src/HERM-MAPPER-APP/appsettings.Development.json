{
  "Database": {
    "Provider": "Sqlite",
    "SqliteFilePath": "|DataDirectory|/herm-mapper.db",
    "ConnectionString": ""
  },
  "Diagnostics": {
    "Console": {
      "Enabled": true,
      "LogLevel": "Debug"
    },
    "Sql": {
      "Enabled": false,
      "LogLevel": "Information",
      "IncludeSensitiveData": false,
      "EnableDetailedErrors": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
