@model PasswordSelfServiceViewModel
@{
    ViewData["Title"] = "Profile";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Account</span>
        <h1>Profile</h1>
        <p>Review your account details and change your password.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <section class="content-card">
        <div class="alert alert-success mb-0">@Model.StatusMessage</div>
    </section>
}

<section class="content-card">
    <dl class="detail-grid mb-0">
        <dt>Given name</dt>
        <dd>@Model.GivenName</dd>
        <dt>Last name</dt>
        <dd>@Model.LastName</dd>
        <dt>Email</dt>
        <dd>@Model.Email</dd>
        <dt>Username</dt>
        <dd>@Model.UserName</dd>
        <dt>Role</dt>
        <dd>@Model.RoleName</dd>
    </dl>
</section>

<section class="content-card">
    <form asp-action="Profile" method="post" class="row g-4">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="col-12">
            <label asp-for="CurrentPassword" class="form-label"></label>
            <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
        </div>
        <div class="col-lg-6" data-password-strength-root>
            <label asp-for="NewPassword" class="form-label"></label>
            <input asp-for="NewPassword" class="form-control" autocomplete="new-password" data-password-input />
            <span asp-validation-for="NewPassword" class="text-danger small"></span>
            <div class="password-strength mt-3">
                <div class="password-strength-track">
                    <div class="password-strength-bar" data-password-strength-bar data-strength-tone="weak"></div>
                </div>
                <div class="password-strength-label" data-password-strength-label>Weak</div>
            </div>
        </div>
        <div class="col-lg-6">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>
        <div class="col-12 d-flex justify-content-end">
            <button class="btn btn-primary" type="submit">Save password</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}