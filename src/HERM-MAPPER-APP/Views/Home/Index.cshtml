@model HomeDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="hero-panel">
    <div>
        <span class="eyebrow">Reference-guided technology mapping</span>
        <h1>Map your component catalogue onto the HERM TRM model.</h1>
        <p class="hero-copy">
            Keep a working catalogue of components, browse the HERM technology reference hierarchy, and export completed mappings to CSV.
        </p>
        <div class="d-flex flex-wrap gap-3 mt-4">
            <a class="btn btn-primary btn-lg" asp-controller="Products" asp-action="Create">Add component</a>
            <a class="btn btn-outline-light btn-lg" asp-controller="Mappings" asp-action="Index">Open mapping board</a>
        </div>
    </div>
    <div class="hero-side">
        <div class="hero-metric">
            <span class="metric-label">Reference model</span>
            <span class="metric-value small">@(Model.HasReferenceModel ? "Imported and ready for mapping." : "No TRM model imported yet.")</span>
        </div>
    </div>
</section>

<section class="stats-grid">
    <article class="stat-card">
        <span class="stat-label">Components</span>
        <span class="stat-value">@Model.ProductCount</span>
        <span class="stat-meta">Catalogue items tracked in SQLite</span>
    </article>
    <article class="stat-card">
        <span class="stat-label">Completed mappings</span>
        <span class="stat-value">@Model.CompletedMappings</span>
        <span class="stat-meta">Ready for CSV export</span>
    </article>
    <article class="stat-card">
        <span class="stat-label">TRM domains</span>
        <span class="stat-value">@Model.DomainCount</span>
        <span class="stat-meta">Imported reference domains</span>
    </article>
    <article class="stat-card">
        <span class="stat-label">TRM capabilities</span>
        <span class="stat-value">@Model.CapabilityCount</span>
        <span class="stat-meta">Imported capability nodes</span>
    </article>
    <article class="stat-card">
        <span class="stat-label">TRM components</span>
        <span class="stat-value">@Model.ReferenceComponentCount</span>
        <span class="stat-meta">Searchable component catalogue</span>
    </article>
</section>

<section class="content-card">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Recent catalogue changes</span>
            <h2>Latest components</h2>
        </div>
        <a class="btn btn-sm btn-outline-primary" asp-controller="Products" asp-action="Index">View all</a>
    </div>

    @if (Model.RecentProducts.Count == 0)
    {
        <div class="empty-state">
            <h3>No components yet</h3>
            <p>Add the components you want to classify, then use the mapping board to align them to HERM TRM.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Component</th>
                        <th>Status</th>
                        <th>Mapped component</th>
                        <th>Updated</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var product in Model.RecentProducts)
                {
                    var latestMapping = product.Mappings
                        .OrderByDescending(x => x.UpdatedUtc)
                        .FirstOrDefault();
                    <tr>
                        <td>
                            <strong>@product.Name</strong>
                            @if (!string.IsNullOrWhiteSpace(product.Vendor))
                            {
                                <div class="table-subline">@product.Vendor @product.Version</div>
                            }
                        </td>
                        <td>
                            @if (latestMapping is null)
                            {
                                <span class="status-pill status-draft">Unmapped</span>
                            }
                            else
                            {
                                <span class="status-pill status-@latestMapping.MappingStatus.ToString().ToLowerInvariant()">@latestMapping.MappingStatus</span>
                            }
                        </td>
                        <td>@(latestMapping?.TrmComponent is null ? $"{product.Mappings.Count} mapping(s)" : latestMapping.TrmComponent.DisplayLabel)</td>
                        <td>@product.UpdatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end">
                            @if (latestMapping is null)
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-controller="Mappings" asp-action="Create" asp-route-productId="@product.Id">Add mapping</a>
                            }
                            else
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-controller="Mappings" asp-action="Edit" asp-route-id="@latestMapping.Id">Modify mapping</a>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
