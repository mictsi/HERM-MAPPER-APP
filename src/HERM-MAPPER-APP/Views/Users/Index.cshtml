@model UsersIndexViewModel
@{
    ViewData["Title"] = "Users";
    ViewData["AdminNav"] = "Users";
    var pageStart = Math.Max(1, Model.Page - 2);
    var pageEnd = Math.Min(Model.TotalPages, Model.Page + 2);
}

<div class="admin-shell">
    @await Html.PartialAsync("_AdminSidebar")
    <div class="admin-content">
        <section class="page-header">
            <div>
                <span class="eyebrow">Administration</span>
                <h1>Users</h1>
                <p>Create, update, delete, and reset passwords for local application users.</p>
            </div>
            <a class="btn btn-primary" asp-action="Create">Create user</a>
        </section>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <section class="content-card">
                <div class="alert alert-success mb-0">@Model.StatusMessage</div>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <section class="content-card">
                <div class="alert alert-danger mb-0">@Model.ErrorMessage</div>
            </section>
        }

        <section class="content-card">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-lg-10">
                    <label class="form-label" for="search">Search users</label>
                    <input class="form-control"
                           id="search"
                           name="search"
                           value="@Model.Search"
                           placeholder="Name, email, username, or role" />
                </div>
                <div class="col-lg-2 d-grid">
                    <button class="btn btn-primary" type="submit">Search</button>
                </div>
            </form>
        </section>

        <section class="content-card">
            @if (Model.TotalCount == 0)
            {
                <div class="empty-state compact">
                    <h3>@(string.IsNullOrWhiteSpace(Model.Search) ? "No users" : "No matching users")</h3>
                    <p>
                        @(string.IsNullOrWhiteSpace(Model.Search)
                            ? "Create the first user account."
                            : "Try a broader search term.")
                    </p>
                </div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
                    <div class="table-subline">
                        Showing @Model.FirstItemNumber-@Model.LastItemNumber of @Model.TotalCount users
                    </div>
                    @if (Model.TotalPages > 1)
                    {
                        <div class="table-subline">Page @Model.Page of @Model.TotalPages</div>
                    }
                </div>

                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Username</th>
                                <th>Role</th>
                                <th>Password changed</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.DisplayName</td>
                                <td>@user.Email</td>
                                <td>@user.UserName</td>
                                <td>@user.RoleName</td>
                                <td>@await TimeZoneDisplay.FormatUtcAsync(user.PasswordChangedUtc)</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@user.Id">Edit</a>
                                        <a class="btn btn-outline-secondary" asp-action="ResetPassword" asp-route-id="@user.Id">Reset password</a>
                                        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@user.Id">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Users pagination" class="mt-3">
                        <ul class="pagination mb-0 flex-wrap">
                            <li class="page-item @(Model.HasPreviousPage ? string.Empty : "disabled")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-search="@Model.Search"
                                   asp-route-page="@(Model.Page - 1)">Previous</a>
                            </li>
                            @for (var pageNumber = pageStart; pageNumber <= pageEnd; pageNumber++)
                            {
                                <li class="page-item @(pageNumber == Model.Page ? "active" : string.Empty)">
                                    <a class="page-link"
                                       asp-action="Index"
                                       asp-route-search="@Model.Search"
                                       asp-route-page="@pageNumber">@pageNumber</a>
                                </li>
                            }
                            <li class="page-item @(Model.HasNextPage ? string.Empty : "disabled")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-search="@Model.Search"
                                   asp-route-page="@(Model.Page + 1)">Next</a>
                            </li>
                        </ul>
                    </nav>
                }
            }
        </section>
    </div>
</div>
