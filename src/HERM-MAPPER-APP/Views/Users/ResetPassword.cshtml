@model UserResetPasswordViewModel
@{
    ViewData["Title"] = "Reset password";
    ViewData["AdminNav"] = "Users";
}

<div class="admin-shell">
    @await Html.PartialAsync("_AdminSidebar")
    <div class="admin-content">
        <section class="page-header">
            <div>
                <span class="eyebrow">Administration</span>
                <h1>Reset password</h1>
                <p>@Model.DisplayName (@Model.UserName)</p>
            </div>
        </section>

        <section class="content-card">
            <form asp-action="ResetPassword" method="post" class="row g-4">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="col-lg-6" data-password-strength-root>
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" autocomplete="new-password" data-password-input />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                    <div class="password-strength mt-3">
                        <div class="password-strength-track">
                            <div class="password-strength-bar" data-password-strength-bar data-strength-tone="weak"></div>
                        </div>
                        <div class="password-strength-label" data-password-strength-label>Weak</div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
                <div class="col-12 d-flex justify-content-end gap-2">
                    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                    <button class="btn btn-primary" type="submit">Save password</button>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}