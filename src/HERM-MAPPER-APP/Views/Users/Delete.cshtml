@model UserDeleteViewModel
@{
    ViewData["Title"] = "Delete user";
    ViewData["AdminNav"] = "Users";
}

<div class="admin-shell">
    @await Html.PartialAsync("_AdminSidebar")
    <div class="admin-content">
        <section class="page-header">
            <div>
                <span class="eyebrow">Administration</span>
                <h1>Delete user</h1>
            </div>
        </section>

        <section class="content-card">
            <dl class="detail-grid">
                <dt>Given name</dt>
                <dd>@Model.GivenName</dd>
                <dt>Last name</dt>
                <dd>@Model.LastName</dd>
                <dt>Email</dt>
                <dd>@Model.Email</dd>
                <dt>Username</dt>
                <dd>@Model.UserName</dd>
                <dt>Role</dt>
                <dd>@Model.RoleName</dd>
            </dl>
            <form asp-action="DeleteConfirmed" method="post" class="d-flex justify-content-end gap-2 mt-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                <button class="btn btn-outline-danger" type="submit">Delete user</button>
            </form>
        </section>
    </div>
</div>