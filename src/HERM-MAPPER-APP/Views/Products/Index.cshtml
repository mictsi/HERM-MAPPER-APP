@model ProductsIndexViewModel
@{
    ViewData["Title"] = "Product Catalogue";
    var ownerFilterSummary = Model.SelectedOwners.Count switch
    {
        0 => "Filter by owner",
        1 => Model.SelectedOwners[0],
        _ => $"{Model.SelectedOwners.Count} owners selected"
    };
}

<section class="page-header">
    <div>
        <span class="eyebrow">Working catalogue</span>
        <h1>Products to classify</h1>
        <p>Track what needs to be mapped and keep ownership, versioning, and notes in one place. Bulk imports are managed from Configuration.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Add product</a>
</section>

<section class="content-card">
    <form method="get" class="row g-3 align-items-start product-filter-form">
        <div class="col-lg-5">
            <label class="form-label" for="search">Search products</label>
            <input class="form-control" id="search" name="search" value="@Model.Search" placeholder="Product, vendor, version, owners, lifecycle" />
        </div>
        <div class="col-lg-4">
            <label class="form-label" for="ownerFilterSummary">Owners</label>
            <details class="owner-filter-dropdown" data-owner-dropdown>
                <summary class="form-select owner-filter-summary" id="ownerFilterSummary">
                    <span data-owner-dropdown-label data-default-label="Filter by owner">@ownerFilterSummary</span>
                </summary>
                <div class="owner-filter-menu">
                    <div class="product-owner-checklist">
                        @foreach (var owner in Model.AvailableOwners)
                        {
                            var optionId = $"owner-{owner.Id}";
                            <label class="product-owner-option" for="@optionId">
                                <input type="checkbox"
                                       id="@optionId"
                                       name="owners"
                                       value="@owner.Value"
                                       data-owner-label="@owner.Value"
                                       @(Model.SelectedOwners.Contains(owner.Value, StringComparer.OrdinalIgnoreCase) ? "checked" : null) />
                                <span>@owner.Value</span>
                            </label>
                        }
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-2 gap-2">
                        <div class="small text-muted">Choose one or more owners.</div>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-owner-clear>Clear</button>
                    </div>
                </div>
            </details>
        </div>
        <div class="col-lg-3">
            <label class="form-label" for="lifecycleStatus">Lifecycle</label>
            <select class="form-select" id="lifecycleStatus" name="lifecycleStatus">
                <option value="">All lifecycle states</option>
                @foreach (var option in Model.LifecycleStatuses)
                {
                    <option value="@option.Value" selected="@(string.Equals(Model.LifecycleStatus, option.Value, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@option.Value</option>
                }
            </select>
        </div>
        <div class="col-lg-12 d-flex justify-content-end">
            <button class="btn btn-primary" type="submit">Go</button>
        </div>
    </form>
</section>

<section class="content-card">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Products</span>
            <h2>@Model.Products.Count result(s)</h2>
        </div>
    </div>

    @if (Model.Products.Count == 0)
    {
        <div class="empty-state compact">
            <h3>No matching products</h3>
            <p>Try a wider search or clear the filters.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Owners</th>
                        <th>Lifecycle</th>
                        <th>Mappings</th>
                        <th>Updated</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Products)
                {
                    var latestMapping = item.Mappings.OrderByDescending(x => x.UpdatedUtc).FirstOrDefault();
                    <tr>
                        <td>
                            <strong>@item.Name</strong>
                            <div class="table-subline">@item.Vendor @item.Version</div>
                        </td>
                        <td>@(item.OwnerDisplay ?? "-")</td>
                        <td>@(string.IsNullOrWhiteSpace(item.LifecycleStatus) ? "-" : item.LifecycleStatus)</td>
                        <td>
                            <strong>@item.Mappings.Count mapping(s)</strong>
                            <div class="table-subline">
                                @(latestMapping?.TrmComponent is null ? "No mapped component yet" : latestMapping.TrmComponent.DisplayLabel)
                            </div>
                        </td>
                        <td>@item.UpdatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Show details</a>
                                <a class="btn btn-outline-secondary" asp-action="Visualize" asp-route-id="@item.Id">Visualize</a>
                                <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
