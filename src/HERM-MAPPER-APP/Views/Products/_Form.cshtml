@model ProductEditViewModel

<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="content-card h-100">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">Catalogue entry</span>
                    <h2>Product details</h2>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Version" class="form-label"></label>
                    <input asp-for="Version" class="form-control" />
                    <span asp-validation-for="Version" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Vendor" class="form-label"></label>
                    <input asp-for="Vendor" class="form-control" />
                    <span asp-validation-for="Vendor" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Owners" class="form-label"></label>
                    <div class="product-owner-checklist product-owner-checklist-compact">
                        @for (var index = 0; index < Model.OwnerOptions.Count; index++)
                        {
                            var owner = Model.OwnerOptions[index];
                            var optionId = $"product-owner-{index}";
                            <label class="product-owner-option" for="@optionId">
                                <input type="checkbox"
                                       id="@optionId"
                                       name="Owners"
                                       value="@owner.Value"
                                       @(owner.Selected ? "checked" : null) />
                                <span>@owner.Text</span>
                            </label>
                        }
                    </div>
                    <div class="small text-muted mt-2">Select one or more owners.</div>
                    <span asp-validation-for="Owners" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="LifecycleStatus" class="form-label"></label>
                    <select asp-for="LifecycleStatus" asp-items="Model.LifecycleStatusOptions" class="form-select"></select>
                    <span asp-validation-for="LifecycleStatus" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <aside class="content-card h-100">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">Workflow</span>
                    <h2>Next step</h2>
                </div>
            </div>
            <p class="mb-3">Save the catalogue record first. Then add one or more mappings for it from the mapping board.</p>
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">Save product</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </div>
        </aside>
    </div>
</div>
