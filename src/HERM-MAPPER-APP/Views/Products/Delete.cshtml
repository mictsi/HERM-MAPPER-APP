@model ProductCatalogItem
@{
    ViewData["Title"] = "Trash Product";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Catalogue CRUD</span>
        <h1>Move @Model.Name to trash?</h1>
        <p>This hides the product from the catalogue. Administrators can restore it or permanently delete it later from Admin.</p>
    </div>
</section>

<section class="content-card">
    <dl class="detail-grid mb-4">
        <dt>Product</dt>
        <dd>@Model.Name</dd>
        <dt>Vendor</dt>
        <dd>@(Model.Vendor ?? "-")</dd>
        <dt>Mappings</dt>
        <dd>@Model.Mappings.Count</dd>
    </dl>

    <form asp-action="Delete" method="post" class="d-flex gap-2">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Move to trash</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </form>
</section>
