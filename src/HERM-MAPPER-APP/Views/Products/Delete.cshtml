@model ProductCatalogItem
@{
    ViewData["Title"] = "Delete Component";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Catalogue CRUD</span>
        <h1>Delete @Model.Name?</h1>
        <p>This removes the component and all of its stored HERM mappings from SQLite.</p>
    </div>
</section>

<section class="content-card">
    <dl class="detail-grid mb-4">
        <dt>Component</dt>
        <dd>@Model.Name</dd>
        <dt>Vendor</dt>
        <dd>@(Model.Vendor ?? "-")</dd>
        <dt>Mappings</dt>
        <dd>@Model.Mappings.Count</dd>
    </dl>

    <form asp-action="Delete" method="post" class="d-flex gap-2">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </form>
</section>
