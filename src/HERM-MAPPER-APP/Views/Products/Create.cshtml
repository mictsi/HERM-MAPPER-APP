@model ProductCatalogItem
@{
    ViewData["Title"] = "Add Product";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Catalogue CRUD</span>
        <h1>Add a product</h1>
        <p>Create the catalogue item first, then assign one or more HERM mappings.</p>
    </div>
</section>

<form asp-action="Create" method="post">
    <partial name="_Form" model="Model" />
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
