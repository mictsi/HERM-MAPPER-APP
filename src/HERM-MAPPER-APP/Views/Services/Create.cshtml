@model ServiceEditViewModel
@{
    ViewData["Title"] = "Add Service";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Service design</span>
        <h1>Add a service</h1>
        <p>Save the service details first, then you will continue on the new Connect products page.</p>
    </div>
</section>

<form asp-action="Create" method="post">
    <partial name="_DetailsForm" model="Model" />
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
