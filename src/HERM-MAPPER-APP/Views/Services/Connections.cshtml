@model ServiceConnectionEditorViewModel
@{
    ViewData["Title"] = "Connect Products";
    var paletteProducts = Model.ProductOptions
        .Where(option => !string.IsNullOrWhiteSpace(option.Value))
        .ToList();
}

<section class="page-header">
    <div>
        <span class="eyebrow">Connect products</span>
        <h1>@Model.ServiceName</h1>
        <p>Build the connected product map on its own page, including branches and merges.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary" asp-action="Index">Back to services</a>
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.ServiceId">Edit details</a>
        <a class="btn btn-primary" asp-action="Visualize" asp-route-id="@Model.ServiceId">Visualize</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <section class="content-card">
        <div class="alert alert-success mb-0" role="status">@Model.StatusMessage</div>
    </section>
}

@if (Model.UsesLegacyFlow)
{
    <section class="content-card">
        <div class="alert alert-info mb-0">
            This service came from the old linear connected-products flow. Saving here converts it to the new connection designer.
        </div>
    </section>
}

<form asp-action="Connections" asp-route-id="@Model.ServiceId" method="post">
    <section class="content-card">
        <div class="detail-grid">
            <div>
                <div class="detail-label">Owner</div>
                <div>@Model.ServiceOwner</div>
            </div>
            <div>
                <div class="detail-label">Lifecycle</div>
                <div>@Model.ServiceLifecycleStatus</div>
            </div>
            <div>
                <div class="detail-label">Description</div>
                <div>@(string.IsNullOrWhiteSpace(Model.ServiceDescription) ? "No description provided." : Model.ServiceDescription)</div>
            </div>
        </div>
    </section>

    <section class="content-card service-canvas-editor" data-service-canvas-editor>
        <div class="section-heading">
            <div>
                <span class="eyebrow">Connected products</span>
                <h2>Connect products</h2>
                <p>Build the service map directly on the canvas. Drag products in, move them where they belong, then use the connector wand to draw the links.</p>
            </div>
        </div>

        <div asp-validation-for="ConnectionRows" class="text-danger mb-2"></div>
        <div asp-validation-for="CanvasStateJson" class="text-danger mb-3"></div>
        <input asp-for="CanvasStateJson" type="hidden" data-service-canvas-state-input />

        <div class="service-canvas-layout">
            <aside class="service-canvas-palette">
                <div class="service-canvas-palette-heading">
                    <span class="eyebrow">Palette</span>
                    <h3>Products</h3>
                    <p>Search, then drag products into the workspace or click once to place them.</p>
                </div>

                @if (paletteProducts.Count == 0)
                {
                    <div class="form-note mb-0">
                        Add products in the product catalogue first. Once products exist, you can place them here.
                    </div>
                }
                else
                {
                    <div class="service-canvas-palette-search">
                        <input type="search"
                               class="form-control form-control-sm"
                               placeholder="Search products"
                               aria-label="Search products"
                               data-service-canvas-palette-search />
                    </div>
                    <div class="service-canvas-palette-list">
                        @foreach (var product in paletteProducts)
                        {
                            <button type="button"
                                    class="service-canvas-product"
                                    draggable="true"
                                    data-service-canvas-product
                                    data-product-id="@product.Value"
                                    data-product-label="@product.Text">
                                <span class="service-canvas-product-title">@product.Text</span>
                            </button>
                        }
                    </div>
                    <div class="service-canvas-palette-empty" data-service-canvas-palette-empty hidden>
                        No products match that search.
                    </div>
                }
            </aside>

            <div class="service-canvas-workspace">
                <div class="service-canvas-toolbar">
                    <div>
                        <div class="service-canvas-toolbar-title">Workspace</div>
                        <p>Move products until the map feels right. Click <strong>Connect</strong> on one node, then click another node to add or remove the connection.</p>
                    </div>
                    <div class="service-canvas-toolbar-actions">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-service-canvas-autolayout>Auto layout</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-service-canvas-clear>Clear canvas</button>
                    </div>
                </div>

                <div class="service-canvas-connector-banner" data-service-canvas-connector-banner hidden></div>
                <div class="service-canvas-selection-banner" data-service-canvas-selection-banner hidden>
                    <span data-service-canvas-selection-copy></span>
                    <button type="button" class="btn btn-sm btn-outline-danger" data-service-canvas-selection-remove>
                        Remove connection
                    </button>
                </div>

                <div class="service-canvas-board" data-service-canvas-board>
                    <div class="service-canvas-surface" data-service-canvas-surface tabindex="0">
                        <svg class="service-canvas-lines" data-service-canvas-lines aria-hidden="true"></svg>
                        <div class="service-canvas-empty" data-service-canvas-empty>
                            <h3>Start with products</h3>
                            <p>Drag products from the left into the canvas to build the flow.</p>
                        </div>
                        <div class="service-canvas-nodes" data-service-canvas-nodes></div>
                    </div>
                </div>

                <div class="service-canvas-footer">
                    <div class="service-canvas-summary" data-service-canvas-summary>
                        0 products on canvas. 0 connections.
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn btn-primary">Save connected products</button>
                        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.ServiceId">Edit details</a>
                        <a class="btn btn-outline-secondary" asp-action="Visualize" asp-route-id="@Model.ServiceId">Visualize</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
