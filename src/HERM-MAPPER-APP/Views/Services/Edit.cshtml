@model ServiceEditViewModel
@{
    ViewData["Title"] = "Edit Service";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Service design</span>
        <h1>Edit @Model.Name</h1>
        <p>Update the service metadata here, then use the separate Connect products page for the connected products.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-action="Connections" asp-route-id="@Model.Id">Connect products</a>
        <a class="btn btn-outline-secondary" asp-action="Visualize" asp-route-id="@Model.Id">Visualize</a>
    </div>
</section>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    <partial name="_DetailsForm" model="Model" />
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
