@using HERMMapperApp
@using HERMMapperApp.Models
@using HERMMapperApp.Services
@using HERMMapperApp.ViewModels
@model ReferenceCatalogueViewModel
@{
    ViewData["Title"] = "HERM Catalogue";
    var isAdministrator = AppRoles.IsAdministrator(User);
}

<section class="page-header">
    <div>
        <span class="eyebrow">Imported HERM TRM reference</span>
        <h1>Browse domains, capabilities, and components</h1>
        <p>Review the current reference model here. Catalogue imports are verified and applied from Configuration, and deleted components are managed from Admin.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ImportStatusMessage))
{
    <section class="alert alert-success" role="status">
        @Model.ImportStatusMessage
    </section>
}

<section class="content-card">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-lg-5">
            <label class="form-label" for="search">Search components</label>
            <input class="form-control" id="search" name="search" value="@Model.Search" placeholder="Code, name, description, product examples" />
        </div>
        <div class="col-lg-3">
            <label class="form-label" for="domainId">Domain</label>
            <select class="form-select" id="domainId" name="domainId">
                <option value="">All domains</option>
                @foreach (var domain in Model.Domains)
                {
                    <option value="@domain.Id" selected="@(Model.DomainId == domain.Id ? "selected" : null)">@domain.Code @domain.Name</option>
                }
            </select>
        </div>
        <div class="col-lg-3">
            <label class="form-label" for="capabilityId">Capability</label>
            <select class="form-select" id="capabilityId" name="capabilityId">
                <option value="">All capabilities</option>
                @foreach (var capability in Model.Capabilities)
                {
                    <option value="@capability.Id" selected="@(Model.CapabilityId == capability.Id ? "selected" : null)">@capability.Code @capability.Name</option>
                }
            </select>
        </div>
        <div class="col-lg-1 d-grid">
            <button class="btn btn-primary" type="submit">Go</button>
        </div>
    </form>
</section>

<div class="row g-4">
    <div class="col-xl-4">
        <section class="content-card h-100">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">Domains</span>
                    <h2>@Model.Domains.Count imported</h2>
                </div>
            </div>
            <div class="stack-list">
                @foreach (var domain in Model.Domains)
                {
                    <article class="stack-item @(Model.DomainId == domain.Id ? "is-selected" : string.Empty)">
                        <div class="stack-title">@domain.Code @domain.Name</div>
                        <div class="stack-body">@domain.Description</div>
                    </article>
                }
            </div>
        </section>
    </div>
    <div class="col-xl-8">
        <section class="content-card">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">Components</span>
                    <h2>@Model.Components.Count result(s)</h2>
                </div>
            </div>

            @if (Model.Components.Count == 0)
            {
                <div class="empty-state compact">
                    <h3>No matching components</h3>
                    <p>Try a wider search or clear the filters.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Component</th>
                                <th>Type</th>
                                <th>Capabilities</th>
                                <th>Domains</th>
                                <th>Product examples</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var component in Model.Components)
                        {
                            var linkedCapabilities = component.CapabilityLinks
                                .Where(x => x.TrmCapability is not null)
                                .Select(x => x.TrmCapability!)
                                .OrderBy(x => x.Code)
                                .ToList();
                            var linkedDomains = linkedCapabilities
                                .Where(x => x.ParentDomain is not null)
                                .Select(x => x.ParentDomain!)
                                .DistinctBy(x => x.Id)
                                .OrderBy(x => x.Code)
                                .ToList();
                            <tr>
                                <td>
                                    <strong>@component.DisplayLabel</strong>
                                    <div class="table-subline">@component.Description</div>
                                </td>
                                <td>
                                    <span class="tag-pill @(component.IsCustom ? "tag-pill-custom" : "tag-pill-model")">
                                        @(component.IsCustom ? "Custom" : "Model")
                                    </span>
                                </td>
                                <td>
                                    @if (linkedCapabilities.Count == 0)
                                    {
                                        <span>-</span>
                                    }
                                    else
                                    {
                                        <div class="mapping-chip-list">
                                            @foreach (var capability in linkedCapabilities)
                                            {
                                                <span class="mapping-chip">@capability.Code @capability.Name</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (linkedDomains.Count == 0)
                                    {
                                        <span>-</span>
                                    }
                                    else
                                    {
                                        <div class="mapping-chip-list">
                                            @foreach (var domain in linkedDomains)
                                            {
                                                <span class="mapping-chip">@domain.Code @domain.Name</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td>@(string.IsNullOrWhiteSpace(component.ProductExamples) ? "-" : component.ProductExamples)</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a class="btn btn-outline-secondary" asp-action="History" asp-route-id="@component.Id">History</a>
                                        @if (isAdministrator)
                                        {
                                        <form asp-action="DeleteComponent" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@component.Id" />
                                            <button class="btn btn-outline-danger" type="submit">Trash</button>
                                        </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
</div>

