<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HERM Mapper</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HERM_MAPPER_APP.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="shell-header">
            <div class="container-xxl">
                <nav class="navbar navbar-expand-lg">
                    <a class="navbar-brand brand-lockup" asp-controller="Home" asp-action="Index">
                        <span class="brand-mark">H</span>
                        <span>
                            <span class="brand-title">HERM Mapper</span>
                            <span class="brand-subtitle">TRM alignment workspace</span>
                        </span>
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse justify-content-end" id="mainNav">
                        <ul class="navbar-nav gap-lg-2">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Products" asp-action="Index">Product</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Configuration" asp-action="Index">Configuration</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reference" asp-action="Index">HERM Catalogue</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Mappings" asp-action="Index">Mapping Board</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="ChangeLog" asp-action="Index">Change Log</a>
                            </li>
                        </ul>
                    </div>
                </nav>
            </div>
        </header>

        <main class="shell-main">
            <div class="container-xxl">
                @RenderBody()
            </div>
        </main>

        <footer class="shell-footer">
            <div class="container-xxl d-flex flex-column flex-md-row justify-content-between gap-2">
                <span>HERM Mapper on .NET 10 with SQLite persistence.</span>
                <span>Reference models can be verified and imported from uploaded HERM TRM workbooks.</span>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
