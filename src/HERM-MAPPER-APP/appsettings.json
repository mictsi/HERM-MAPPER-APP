{
  "ConnectionStrings": {
    "Sqlite": "Data Source=|DataDirectory|/herm-mapper.db",
    "DefaultConnection": "Data Source=|DataDirectory|/herm-mapper.db"
  },
  "Database": {
    "Provider": "Sqlite",
    "SqliteFilePath": "|DataDirectory|/herm-mapper.db",
    "ConnectionString": ""
  },
  "HermWorkbook": {
    "Path": "",
    "AutoImportOnFirstRun": false
  },
  "SampleRelationships": {
    "Path": "",
    "AutoImportOnFirstRun": false
  },
  "Security": {
    "BootstrapAdmin": {
      "GivenName": "System",
      "LastName": "Administrator",
      "Email": "admin@local",
      "UserName": "admin",
      "Password": "ChangeMeNow!123"
    },
    "Authentication": {
      "SessionTimeoutMinutes": 60,
      "MaxFailedLoginAttempts": 15,
      "LockoutMinutes": 1
    }
  },
  "Diagnostics": {
    "Console": {
      "Enabled": true,
      "LogLevel": "Information"
