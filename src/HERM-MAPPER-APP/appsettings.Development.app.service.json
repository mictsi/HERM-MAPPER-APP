{
  "ConnectionStrings": {
    "Sqlite": "Data Source=|HomeDirectory|/data/herm-mapper.db",
    "DefaultConnection": "Data Source=|HomeDirectory|/data/herm-mapper.db"
  },
  "Database": {
    "Provider": "Sqlite",
    "SqliteFilePath": "|HomeDirectory|/data/herm-mapper.db",
    "ConnectionString": ""
  },
  "Security": {
    "Authentication": {
      "Local": {
        "Enabled": true
      },
      "OpenIdConnect": {
        "Enabled": false,
        "DisplayName": "OpenID Connect",
        "Authority": "",
        "MetadataAddress": "",
        "ClientId": "",
        "ClientSecret": "",
        "CallbackPath": "/signin-oidc",
        "SignedOutCallbackPath": "/signout-callback-oidc",
        "RequireHttpsMetadata": true,
        "GetClaimsFromUserInfoEndpoint": false,
        "NameClaimType": "name",
        "EmailClaimType": "email",
        "GivenNameClaimType": "given_name",
        "SurnameClaimType": "family_name",
        "GroupClaimType": "groups",
        "SubjectClaimType": "sub",
        "Scopes": [
          "openid",
          "profile",
          "email"
        ],
        "RoleGroupMappings": {
          "Administrator": [],
          "Contributor": [],
          "Viewer": []
        }
      }
    }
  },
  "Diagnostics": {
    "Console": {
      "Enabled": true,
      "LogLevel": "Error"
    },
    "Sql": {
      "Enabled": false,
      "LogLevel": "Information",
      "IncludeSensitiveData": false,
      "EnableDetailedErrors": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
