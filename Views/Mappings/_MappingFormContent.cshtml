@model MappingEditViewModel

<div class="row g-4">
    <div class="col-xl-4">
        <section class="content-card h-100">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">Source record</span>
                    <h2>Product context</h2>
                </div>
            </div>
            <dl class="detail-grid">
                <dt>Owner</dt>
                <dd>@(Model.Owner ?? "-")</dd>
                <dt>Lifecycle</dt>
                <dd>@(Model.LifecycleStatus ?? "-")</dd>
                <dt>Description</dt>
                <dd>@(Model.Description ?? "-")</dd>
            </dl>
        </section>
    </div>
    <div class="col-xl-8">
        <section class="content-card">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">Classification</span>
                    <h2>Assign the HERM node</h2>
                </div>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="SelectedDomainId" class="form-label"></label>
                    <select asp-for="SelectedDomainId" asp-items="Model.Domains" class="form-select" id="domainSelect">
                        <option value="">Choose a domain</option>
                    </select>
                    <span asp-validation-for="SelectedDomainId" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="SelectedCapabilityId" class="form-label"></label>
                    <select asp-for="SelectedCapabilityId" asp-items="Model.Capabilities" class="form-select" id="capabilitySelect">
                        <option value="">Choose a capability</option>
                    </select>
                    <span asp-validation-for="SelectedCapabilityId" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="SelectedComponentId" class="form-label"></label>
                    <select asp-for="SelectedComponentId" asp-items="Model.Components" class="form-select" id="componentSelect">
                        <option value="">Choose a component</option>
                    </select>
                    <span asp-validation-for="SelectedComponentId" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="MappingStatus" class="form-label"></label>
                    <select asp-for="MappingStatus" asp-items="Html.GetEnumSelectList<MappingStatus>()" class="form-select"></select>
                    <span asp-validation-for="MappingStatus" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="FitScore" class="form-label"></label>
                    <input asp-for="FitScore" class="form-control" min="1" max="5" />
                    <span asp-validation-for="FitScore" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="MappingRationale" class="form-label"></label>
                    <textarea asp-for="MappingRationale" class="form-control" rows="6" placeholder="Why is this the right HERM TRM classification?"></textarea>
                    <span asp-validation-for="MappingRationale" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save mapping</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </div>
        </section>
    </div>
</div>
