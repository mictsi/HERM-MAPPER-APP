@model ReferenceCatalogueViewModel
@{
    ViewData["Title"] = "HERM Catalogue";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Imported HERM TRM reference</span>
        <h1>Browse domains, capabilities, and components</h1>
        <p>Review the current reference model and upload verified workbook updates when the catalogue changes.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ImportStatusMessage))
{
    <section class="alert alert-success" role="status">
        @Model.ImportStatusMessage
    </section>
}

<section class="content-card">
    <div class="section-heading">
        <div>
            <span class="eyebrow">TRM model import</span>
            <h2>Verify before importing</h2>
        </div>
    </div>
    <form asp-action="VerifyImport" method="post" enctype="multipart/form-data" class="row g-3 align-items-end">
        <div class="col-lg-8">
            <label class="form-label" for="workbook">Upload workbook</label>
            <input class="form-control" id="workbook" name="workbook" type="file" accept=".xlsx" />
        </div>
        <div class="col-lg-4 d-grid">
            <button class="btn btn-primary" type="submit">Verify workbook</button>
        </div>
    </form>

    @if (Model.ImportReview.HasReview && Model.ImportReview.Verification is not null)
    {
        <div class="import-review">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">Verification result</span>
                    <h3>@(Model.ImportReview.UploadedFileName ?? "Uploaded workbook")</h3>
                </div>
                <span class="status-pill @(Model.ImportReview.Verification.IsValid ? "status-complete" : "status-outofscope")">
                    @(Model.ImportReview.Verification.IsValid ? "Ready to import" : "Verification failed")
                </span>
            </div>

            <div class="stats-grid stats-grid-compact import-stats">
                <article class="stat-card">
                    <span class="stat-label">Domains</span>
                    <span class="stat-value">@Model.ImportReview.Verification.DomainRowCount</span>
                    <span class="stat-meta">+@Model.ImportReview.Verification.DomainsToAdd new, @Model.ImportReview.Verification.DomainsToUpdate update</span>
                </article>
                <article class="stat-card">
                    <span class="stat-label">Capabilities</span>
                    <span class="stat-value">@Model.ImportReview.Verification.CapabilityRowCount</span>
                    <span class="stat-meta">+@Model.ImportReview.Verification.CapabilitiesToAdd new, @Model.ImportReview.Verification.CapabilitiesToUpdate update</span>
                </article>
                <article class="stat-card">
                    <span class="stat-label">Components</span>
                    <span class="stat-value">@Model.ImportReview.Verification.ComponentRowCount</span>
                    <span class="stat-meta">+@Model.ImportReview.Verification.ComponentsToAdd new, @Model.ImportReview.Verification.ComponentsToUpdate update</span>
                </article>
            </div>

            @if (Model.ImportReview.Verification.Errors.Count > 0)
            {
                <div class="alert alert-danger mt-3 mb-0">
                    <strong>Import is blocked.</strong>
                    <ul class="mb-0 mt-2">
                        @foreach (var error in Model.ImportReview.Verification.Errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            @if (Model.ImportReview.Verification.Warnings.Count > 0)
            {
                <div class="alert alert-warning mt-3 mb-0">
                    <ul class="mb-0">
                        @foreach (var warning in Model.ImportReview.Verification.Warnings)
                        {
                            <li>@warning</li>
                        }
                    </ul>
                </div>
            }

            @if (Model.ImportReview.Verification.IsValid && !string.IsNullOrWhiteSpace(Model.ImportReview.PendingImportToken))
            {
                <form asp-action="ImportVerified" method="post" class="mt-3">
                    <input type="hidden" name="pendingImportToken" value="@Model.ImportReview.PendingImportToken" />
                    <button class="btn btn-primary" type="submit">Import verified model</button>
                </form>
            }
        </div>
    }
</section>

<section class="content-card">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-lg-5">
            <label class="form-label" for="search">Search components</label>
            <input class="form-control" id="search" name="search" value="@Model.Search" placeholder="Code, name, description, product examples" />
        </div>
        <div class="col-lg-3">
            <label class="form-label" for="domainId">Domain</label>
            <select class="form-select" id="domainId" name="domainId">
                <option value="">All domains</option>
                @foreach (var domain in Model.Domains)
                {
                    <option value="@domain.Id" selected="@(Model.DomainId == domain.Id ? "selected" : null)">@domain.Code @domain.Name</option>
                }
            </select>
        </div>
        <div class="col-lg-3">
            <label class="form-label" for="capabilityId">Capability</label>
            <select class="form-select" id="capabilityId" name="capabilityId">
                <option value="">All capabilities</option>
                @foreach (var capability in Model.Capabilities)
                {
                    <option value="@capability.Id" selected="@(Model.CapabilityId == capability.Id ? "selected" : null)">@capability.Code @capability.Name</option>
                }
            </select>
        </div>
        <div class="col-lg-1 d-grid">
            <button class="btn btn-primary" type="submit">Go</button>
        </div>
    </form>
</section>

<div class="row g-4">
    <div class="col-xl-4">
        <section class="content-card h-100">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">Domains</span>
                    <h2>@Model.Domains.Count imported</h2>
                </div>
            </div>
            <div class="stack-list">
                @foreach (var domain in Model.Domains)
                {
                    <article class="stack-item @(Model.DomainId == domain.Id ? "is-selected" : string.Empty)">
                        <div class="stack-title">@domain.Code @domain.Name</div>
                        <div class="stack-body">@domain.Description</div>
                    </article>
                }
            </div>
        </section>
    </div>
    <div class="col-xl-8">
        <section class="content-card">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">Components</span>
                    <h2>@Model.Components.Count result(s)</h2>
                </div>
            </div>

            @if (Model.Components.Count == 0)
            {
                <div class="empty-state compact">
                    <h3>No matching components</h3>
                    <p>Try a wider search or clear the filters.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Component</th>
                                <th>Type</th>
                                <th>Capabilities</th>
                                <th>Domains</th>
                                <th>Product examples</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var component in Model.Components)
                        {
                            var linkedCapabilities = component.CapabilityLinks
                                .Where(x => x.TrmCapability is not null)
                                .Select(x => x.TrmCapability!)
                                .OrderBy(x => x.Code)
                                .ToList();
                            var linkedDomains = linkedCapabilities
                                .Where(x => x.ParentDomain is not null)
                                .Select(x => x.ParentDomain!)
                                .DistinctBy(x => x.Id)
                                .OrderBy(x => x.Code)
                                .ToList();
                            <tr>
                                <td>
                                    <strong>@component.DisplayLabel</strong>
                                    <div class="table-subline">@component.Description</div>
                                </td>
                                <td>
                                    <span class="tag-pill @(component.IsCustom ? "tag-pill-custom" : "tag-pill-model")">
                                        @(component.IsCustom ? "Custom" : "Model")
                                    </span>
                                </td>
                                <td>
                                    @if (linkedCapabilities.Count == 0)
                                    {
                                        <span>-</span>
                                    }
                                    else
                                    {
                                        <div class="mapping-chip-list">
                                            @foreach (var capability in linkedCapabilities)
                                            {
                                                <span class="mapping-chip">@capability.Code @capability.Name</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (linkedDomains.Count == 0)
                                    {
                                        <span>-</span>
                                    }
                                    else
                                    {
                                        <div class="mapping-chip-list">
                                            @foreach (var domain in linkedDomains)
                                            {
                                                <span class="mapping-chip">@domain.Code @domain.Name</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td>@(string.IsNullOrWhiteSpace(component.ProductExamples) ? "-" : component.ProductExamples)</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a class="btn btn-outline-secondary" asp-action="History" asp-route-id="@component.Id">History</a>
                                        <form asp-action="DeleteComponent" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@component.Id" />
                                            <button class="btn btn-outline-danger" type="submit">Trash</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
</div>

<section class="content-card">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Trash</span>
            <h2>@Model.TrashedComponents.Count deleted component(s)</h2>
        </div>
    </div>

    @if (Model.TrashedComponents.Count == 0)
    {
        <div class="empty-state compact">
            <h3>Trash is empty</h3>
            <p>Deleted components stay here until they are restored.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Component</th>
                        <th>Deleted</th>
                        <th>Reason</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var component in Model.TrashedComponents)
                {
                    <tr>
                        <td>@component.DisplayLabel</td>
                        <td>@component.DeletedUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@(component.DeletedReason ?? "-")</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a class="btn btn-outline-secondary" asp-action="History" asp-route-id="@component.Id">History</a>
                                <form asp-action="RestoreComponent" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@component.Id" />
                                    <button class="btn btn-outline-primary" type="submit">Restore</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
