@model ProductCatalogItem
@{
    ViewData["Title"] = "Product Details";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Catalogue record</span>
        <h1>@Model.Name</h1>
        <p>@Model.Vendor @Model.Version</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-controller="Mappings" asp-action="Create" asp-route-productId="@Model.Id">Add mapping</a>
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Edit product</a>
    </div>
</section>

<div class="row g-4">
    <div class="col-lg-6">
        <section class="content-card h-100">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">Product metadata</span>
                    <h2>Details</h2>
                </div>
            </div>
            <dl class="detail-grid">
                <dt>Vendor</dt>
                <dd>@(Model.Vendor ?? "-")</dd>
                <dt>Version</dt>
                <dd>@(Model.Version ?? "-")</dd>
                <dt>Owner</dt>
                <dd>@(Model.Owner ?? "-")</dd>
                <dt>Lifecycle</dt>
                <dd>@(Model.LifecycleStatus ?? "-")</dd>
                <dt>Description</dt>
                <dd>@(Model.Description ?? "-")</dd>
                <dt>Notes</dt>
                <dd>@(Model.Notes ?? "-")</dd>
            </dl>
        </section>
    </div>
    <div class="col-lg-6">
        <section class="content-card h-100">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">HERM alignment</span>
                    <h2>@Model.Mappings.Count mapping(s)</h2>
                </div>
            </div>

            @if (Model.Mappings.Count == 0)
            {
                <div class="empty-state compact">
                    <h3>No mappings yet</h3>
                    <p>Create the first HERM TRM relationship for this product.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Domain</th>
                                <th>Component</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var mapping in Model.Mappings.OrderBy(x => x.TrmDomain?.Name ?? string.Empty).ThenBy(x => x.TrmComponent?.Name ?? string.Empty))
                        {
                            <tr>
                                <td><span class="status-pill status-@mapping.MappingStatus.ToString().ToLowerInvariant()">@mapping.MappingStatus</span></td>
                                <td>@(mapping.TrmDomain is null ? "-" : $"{mapping.TrmDomain.Code} {mapping.TrmDomain.Name}")</td>
                                <td>@(mapping.TrmComponent is null ? "-" : $"{mapping.TrmComponent.Code} {mapping.TrmComponent.Name}")</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a class="btn btn-outline-secondary" asp-controller="Mappings" asp-action="Edit" asp-route-id="@mapping.Id">Edit</a>
                                        <a class="btn btn-outline-danger" asp-controller="Mappings" asp-action="Delete" asp-route-id="@mapping.Id">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
</div>
